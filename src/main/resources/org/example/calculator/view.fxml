<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Point3D?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<VBox alignment="CENTER" prefHeight="141.0" prefWidth="188.0" spacing="20.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.calculator.Controller">
   <cursor>
      <Cursor fx:constant="DEFAULT" />
   </cursor>
   <children>
      <Text fx:id="answerText" strokeType="OUTSIDE" strokeWidth="0.0" textOrigin="CENTER" />
      <TextField fx:id="textField" onAction="#onAction" onKeyTyped="#onKeyTyped" prefHeight="26.0" prefWidth="77.0" />
      <Button fx:id="resetButton" alignment="CENTER" mnemonicParsing="false" onAction="#reset" text="Reset" textAlignment="CENTER">
         <rotationAxis>
            <Point3D />
         </rotationAxis>
      </Button>
   </children>
   <padding>
      <Insets left="20.0" right="20.0" />
   </padding>
</VBox>
